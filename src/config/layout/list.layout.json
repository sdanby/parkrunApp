{
  "version": "1.0.0-draft",
  "page": "Lists",
  "units": "cm",
  "anchor": "lists-header-root",
  "notes": "Config-driven Lists page layout with absolute positioning (0,0 = top-left).",
  "viewports": {
    "laptop": {
      "breakpointMin": 641
    },
    "mobile": {
      "breakpointMax": 640
    }
  },
  "elements": [
    {
      "id": "lists.title",
      "type": "label",
      "name": "Top 1000 List",
      "style": {
        "fontSize": "1.0rem",
        "fontWeight": 700,
        "color": "#111827",
        "lineHeight": 1.2
      },
      "laptop": { "x": "0.1cm", "y": "3.8cm" },
      "mobile": { "x": "0.1cm", "y": "2.9cm" }
    },
    {
      "id": "lists.statusLabel",
      "type": "label",
      "name": "retrieving results",
      "style": {
        "fontSize": "0.76rem",
        "fontWeight": 600,
        "color": "#1d4ed8",
        "lineHeight": 1.1
      },
      "laptop": { "x": "4.3cm", "y": "3.8cm" },
      "mobile": { "x": "4.3cm", "y": "2.9cm" }
    },
    {
      "id": "lists.listLabel",
      "type": "label",
      "name": "List selection:",
      "helpTarget": "control-list-select",
      "helpLabel": true,
      "style": {
        "fontSize": "0.8rem",
        "fontWeight": 600,
        "color": "#111827",
        "lineHeight": 1.0
      },
      "laptop": { "x": "0.6cm", "y": "0.2cm" },
      "mobile": { "x": "0.6cm", "y": "-0.7cm" }
    },
    {
      "id": "lists.listSelect",
      "type": "select",
      "name": "Fastest Athletes - All Time",
      "helpLabel": true,
      "options": [
        "Fastest Athletes - All Time",
        "Fastest Athletes - Over last 1 Year",
        "Highest Total Runs",
        "Highest Local Runs",
        "Highest Local Runs - Over last 1 Year"
      ],
      "laptop": { "x": "3.6cm", "y": "0.2cm", "width": "6.5cm" },
      "mobile": { "x": "3.6cm", "y": "-0.7cm", "width": "6.0cm" }
    },
    {
      "id": "lists.participantFilterLabel",
      "type": "label",
      "name": "Participants:",
      "helpTarget": "control-participant-filter",
      "helpLabel": true,
      "style": {
        "fontSize": "0.8rem",
        "fontWeight": 600,
        "color": "#111827",
        "lineHeight": 1.0
      },
      "laptop": { "x": "0.9cm", "y": "0.9cm" },
      "mobile": { "x": "0.9cm", "y": "0.0cm" }
    },
    {
      "id": "lists.participantFilterSelect",
      "type": "select",
      "name": "all participants",
      "helpTarget": "control-participant-filter",
      "helpLabel": true,
      "options": [
        "all participants",
        "Participants >50 total-runs",
        "Participants > 50 local-runs",
        "Participants > 10 local_run_1y"
      ],
      "laptop": { "x": "3.6cm", "y": "0.9cm", "width": "6.5cm" },
      "mobile": { "x": "3.6cm", "y": "0.0cm", "width": "6.0cm" }
    },
    {
      "id": "lists.courseAdjLabel",
      "type": "label",
      "name": "Course adj:",
      "helpTarget": "control-course-adj",
      "helpLabel": true,
      "style": {
        "fontSize": "0.8rem",
        "fontWeight": 600,
        "color": "#111827",
        "lineHeight": 1.0
      },
      "laptop": { "x": "1.0cm", "y": "1.6cm" },
      "mobile": { "x": "1.0cm", "y": "0.7cm" }
    },
    {
      "id": "lists.courseAdjSelect",
      "type": "select",
      "name": "no adjustment (default)",
      "options": [
        "no adjustment (default)",
        "seasonal adjustments",
