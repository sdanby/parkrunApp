      "laptop": { "x": "3.6cm", "y": "2.3cm", "width": "4.5cm" },
      "mobile": { "x": "3.6cm", "y": "1.4cm", "width": "4.5cm" }
    },
    {
      "id": "lists.adjustmentFilterLabel",
      "type": "label",
      "name": "Use adj. filters:",
      "helpTarget": "control-adjustment-filter",
      "helpLabel": true,
      "style": {
        "fontSize": "0.8rem",
        "fontWeight": 600,
        "color": "#111827",
        "lineHeight": 1.0
      },
      "laptop": { "x": "0.5cm", "y": "3.0cm" },
      "mobile": { "x": "0.5cm", "y": "2.1cm" }
    },
    {
      "id": "lists.adjustmentFilterCheckbox",
      "type": "field",
      "name": "filtered by adjustments",
      "laptop": { "x": "3.5cm", "y": "2.9cm", "width": "0.5cm", "height": "0.5cm" },
      "mobile": { "x": "3.5cm", "y": "2.1cm", "width": "0.5cm", "height": "0.5cm" }
    },
    {
      "id": "lists.adjustmentControlsGroup",
      "type": "field",
      "name": "adjustment controls group",
      "style": {
        "border": "1px solid #9ca3af",
        "borderColor": "#9ca3af",
        "borderRadius": "0.22cm",
        "backgroundColor": "transparent"
      },
      "laptop": { "x": "0.35cm", "y": "1.5cm", "width": "8.1cm", "height": "2.2cm" },
      "mobile": { "x": "0.35cm", "y": "0.6cm", "width": "8.1cm", "height": "2.2cm" }
    },
    {
      "id": "lists.tableContainer",
      "type": "table",
      "name": "tableContainer",
      "laptop": { "x": "0.0cm", "y": "4.4cm", "width": "calc(100vw - 1.3cm)", "maxWidth": "calc(100vw - 1.3cm)", "maxHeight": "calc(100vh - 8.0cm)" },
      "mobile": { "x": "-0.1cm", "y": "3.4cm", "width": "calc(100vw - 0.6cm)", "maxWidth": "calc(100vw - 0.6cm)", "maxHeight": "calc(100vh - 7.7cm)" }
    }
  ],
  "tableModel": {
    "mode": "flat",
    "sort": {
      "enabled": true,
      "showInactiveArrows": true,
      "activeColor": "#111827",
      "inactiveColor": "#9ca3af"
    }
  },
  "tableColumns": [
    { "key": "Rank", "type": "table", "name": "Rank", "headerName": "Rk", "style": { "textAlign": "center" }, "sticky": true, "laptop": { "width": "1.2cm" }, "mobile": { "width": "1.2cm" } },
    { "key": "Name", "type": "table", "name": "Name", "headerName": "Name", "style": { "textAlign": "left" }, "sticky": true, "laptop": { "width": "3.8cm" }, "mobile": { "width": "3.3cm" } },
    { "key": "Time", "type": "table", "name": "Time", "headerName": "Time", "style": { "textAlign": "center" }, "laptop": { "width": "1.6cm" }, "mobile": { "width": "1.6cm" } },
