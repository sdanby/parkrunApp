      "mobile": { "x": "3.6cm", "y": "0.7cm", "width": "4.5cm" }
    },
    {
      "id": "lists.otherAdjLabel",
      "type": "label",
      "name": "Other adj:",
      "helpTarget": "control-other-adj",
      "helpLabel": true,
      "style": {
        "fontSize": "0.8rem",
        "fontWeight": 600,
        "color": "#111827",
        "lineHeight": 1.0
      },
      "laptop": { "x": "1.3cm", "y": "2.3cm" },
      "mobile": { "x": "1.3cm", "y": "1.4cm" }
