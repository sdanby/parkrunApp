    {
      "key": "date",
      "type": "table",
      "name": "date",
      "headerName": "Date",
      "helpTarget": "term-date",
      "sticky": true,
      "interaction": {
        "enabled": true,
        "action": "navigate",
        "target": "/races",
        "navMode": "stack",
        "params": {
          "event_code": "$row.event_code",
          "date": "$row.formatted_date",
          "athlete_code": "$row.athlete_code"
        }
      },
      "style": { "textAlign": "left" },
      "laptop": { "width": "75px" },
      "mobile": { "width": "75px" }
    },
    { "key": "event_display", "type": "table", "name": "event_display", "headerName": "Course", "helpTarget": "term-course", "interaction": { "enabled": true, "action": "navigate", "target": "/courses_test", "navMode": "stack", "params": { "event_name": "$row.event_display" } }, "style": { "textAlign": "left" }, "laptop": { "width": "140px" }, "mobile": { "width": "120px" } },
