    { "key": "best_curve_ranking_current", "type": "table", "name": "best_curve_ranking_current", "headerName": "Rank", "helpTarget": "term-rank", "style": { "textAlign": "center", "subFontSize": "0.62rem" }, "laptop": { "width": "60px" }, "mobile": { "width": "60px" } },
    { "key": "comment", "type": "table", "name": "comment", "headerName": "Detail", "helpTarget": "term-detail", "style": { "textAlign": "center" }, "laptop": { "width": "90px" }, "mobile": { "width": "90px" } },

